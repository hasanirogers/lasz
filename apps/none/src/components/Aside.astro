---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
---
<lasz-aside>
 <Image src="/logo.webp" alt="Logo" width={300} height={300} />
  <h1>{SITE_TITLE}</h1>

  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/blog">Blog</a></li>
  </ul>
</lasz-aside>


<style>
  a {
    text-decoration: none;
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }

  h1 {
    font-size: 2rem;
    padding: 1rem 0;
    margin: 1rem 0;
    border-bottom: 1px solid rgb(var(--white));
  }

  lasz-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
  }

  a,
  lasz-aside,
  h1, h2, h3, h4, h5, h6 {
    color: rgb(var(--white));
  }
</style>


---
import Layout from '../layouts/Layout.astro';
import { shopifyQuery, GET_CART_QUERY } from '../shared/shopify';

// 1. Get the cart ID from the server-side cookie
const cartId = Astro.cookies.get('shopify_cart_id')?.value;
let cartData = null;

// 2. If a cart exists, fetch its data on the server
if (cartId) {
  try {
    const data = await shopifyQuery<any>(GET_CART_QUERY, { cartId });
    cartData = data.cart;
  } catch (e) {
    console.error("Failed to fetch cart server-side", e);
  }
}
---

<Layout title="Your Shopping Cart">
  {console.log(cartData)}
  <main>
    <h1>Your Cart</h1>
    <lasz-cart-view initial-cart={JSON.stringify(cartData)}></lasz-cart-view>
  </main>
</Layout>

<script>
  import '../elements/lasz-cart-view/lasz-cart-view.ts';
</script>

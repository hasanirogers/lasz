---
import background from '../assets/background.svg';
import { Image } from 'astro:assets';
---

<lasz-welcome>
	<img class="background" src={background.src} alt="" fetchpriority="high" />
	<main>
    <section>
      <Image class="logo" src="/logo.webp" alt="Lasz Logo" width="360" height="360" />
      <br /><br /><br />
      <h1>Be Bold. Be <span>LASZ</span>.</h1>
      <div>Start your next project with the LASZ stack.</div>
      <br /><br /><br />
      <p><code>npm create lasz-app@latest</code></p>
    </section>
		<lasz-stack></lasz-stack>
	</main>
</lasz-welcome>

<style>
  h1 {
    margin: 0;
    padding: 0;
    font-size: clamp(1.5rem, 5vw, 4rem);

    span {
      color: rgb(var(--lasz-color));
    }
  }

	main {
    color: gray;
		height: 100%;
		display: flex;
		justify-content: center;
		align-items: flex-end;
    background: radial-gradient(circle, transparent 0%, black 80%);
	}

  section {
    position: absolute;
    top: 1rem;
    left: 50%;
    text-align: center;
    transform: translateX(-50%);

    @media screen and (width > 1024px) {
      top: 4rem;
    }
  }

  code {
    color: rgb(var(--lasz-dark-color));
    font-size: 1rem;
    padding: 1rem;
    border-radius: 0.5rem;
    white-space: nowrap;
    border: 2px dashed rgb(var(--lasz-dark-color));
  }

  lasz-welcome {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
	}

  .logo {
    width: auto;
    height: 33vh;

    @media screen and (width > 1024px) {
      width: 300px;
      height: 300px;
    }
  }

  .background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
    opacity: 0.25;
		filter: grayscale(1);
	}
</style>
<script>
  import '../elements/lasz-stack';
</script>

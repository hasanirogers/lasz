---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <lasz-page-main>
    <lasz-page-container>
      <kemet-tabs divider placement="top" selected="orders">
        <kemet-tab slot="tab" link="orders">
          <kemet-icon-bootstrap icon="credit-card" size="24"></kemet-icon-bootstrap>
          Orders
        </kemet-tab>
        <kemet-tab slot="tab" link="addresses">
          <kemet-icon-bootstrap icon="geo-alt" size="24"></kemet-icon-bootstrap>
          Addresses
        </kemet-tab>
        <kemet-tab slot="tab" link="payment-methods">
          <kemet-icon-bootstrap icon="wallet2" size="24"></kemet-icon-bootstrap>
          Payment Methods
        </kemet-tab>
        <kemet-tab slot="tab" link="account-details">
          <kemet-icon-bootstrap icon="person-circle" size="24"></kemet-icon-bootstrap>
          Account Details
        </kemet-tab>
        <kemet-tab slot="tab" link="logout">
          <kemet-icon-bootstrap icon="box-arrow-right" size="24"></kemet-icon-bootstrap>
          <a href="/logout">Logout</a>
        </kemet-tab>

        <kemet-tab-panel slot="panel" panel="orders">
          <lasz-account-orders></lasz-account-orders>
        </kemet-tab-panel>

        <kemet-tab-panel slot="panel" panel="addresses">
          <lasz-account-addresses></lasz-account-addresses>
        </kemet-tab-panel>

        <kemet-tab-panel slot="panel" panel="payment-methods">
          <lasz-account-payments></lasz-account-payments>
        </kemet-tab-panel>

        <kemet-tab-panel slot="panel" panel="account-details">
          <lasz-account-details></lasz-account-details>
        </kemet-tab-panel>
      </kemet-tabs>
    </lasz-page-container>
  </lasz-page-main>
</Layout>
<script>
  import appStore from '../stores/app';
  import userStore from '../stores/user';

  import 'kemet-ui/elements/tabs';
  import 'kemet-ui/elements/tab';
  import 'kemet-ui/elements/tab-panel';
  import type HTMLKemetTabsElement from 'kemet-ui/elements/tabs.d.ts';

  import '../elements/lasz-account/orders';
  import '../elements/lasz-account/addresses';
  import '../elements/lasz-account/details';
  import '../elements/lasz-account/payments';

  const user = userStore.getState();

  if (!user?.isLoggedIn) {
    window.location.href = '/login';
  }

  let slug = window.location.pathname.split('/').pop();

  const tabs = document.querySelector('kemet-tabs') as HTMLKemetTabsElement;
  const deepLinkSlugs = ['orders', 'downloads', 'addresses', 'payment-methods', 'account-details'];

  if (slug && deepLinkSlugs.includes(slug)) {
    tabs.selected = slug;
  } else {
    tabs.selected = 'orders';
  }

  tabs.addEventListener('kemet-change', (event) => {
    const name = (event as CustomEvent).detail.selectedName;
    const hasAccountPrefix = window.location.pathname.startsWith('/account');
    slug = name || 'orders';
    window.history.pushState({}, '', `${hasAccountPrefix ? '/account' : ''}/${name}`);
  });

  const appState = appStore.getState();
  tabs.placement = appState.isMobile ? 'top' : 'left';
  tabs.overflow = appState.isMobile;

  appStore.subscribe((state) => {
    tabs.placement = state.isMobile ? 'top' : 'left';
    tabs.overflow = state.isMobile;
    tabs.selected = slug || 'orders';
  });
</script>
<style>
  lasz-page-container {
    padding: 0 1rem;
  }

  kemet-tabs {
    padding: 0;
    margin: 4rem auto;
  }

  kemet-tab {
    gap: 0.5rem;
    @media (width > 1024px) {
      gap:  1rem;
    }
  }

  [link=logout] {
    width: 100%;
    padding: 0.5rem 1rem;
    display: flex;
    justify-content: flex-start;
    border: 1px solid var(--color-link);

    a {
      width: 100%;
      display: block;
      color: var(--color-text);

      &:hover {
        border: 0;
      }
    }
  }

  ::part(links) {
    @media (width > 1024px) {
      margin: 0 2rem;
    }
  }
</style>

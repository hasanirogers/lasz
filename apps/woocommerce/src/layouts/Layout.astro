---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import 'kemet-ui/styles/kemet.base.css';
import '@wordpress/block-library/build-style/style.css';
import '@wordpress/block-library/build-style/theme.css';
import '../styles/base.css';
import '../styles/cea.css';
import '../styles/wordpress.css';

const { title = 'LaszCommerce' } = Astro.props;

// const API_URL = import.meta.env.PUBLIC_API_URL;
// const REST_CUSTOM_URL = `${API_URL}/wp-json/lasz-woocommerce/v1`;
// const siteLogoData = await fetch(`${REST_CUSTOM_URL}/theme/logo`);
// console.log(siteLogoData);
// const siteLogoFull = (await siteLogoData.json()).full ?? '/logo.webp';

const isLoggedIn = !!Astro.cookies.get('lasz-user');
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content="The world's first LASZ app" />
		<link rel="preload" as="image" href="/logo.webp" fetchpriority="high" />
		<title>{title}</title>
	</head>
	<body>
    <kemet-drawer>
      <aside slot="navigation">
        <kemet-icon-bootstrap icon="x-lg" size="24"></kemet-icon-bootstrap>
        <a href="/"><img src="/logo.webp" alt="LaszCommerce" /></a>
        <nav>
          <a href="/">Home</a>
          <a href="/cart">Cart</a>
          <a href="/checkout">Checkout</a>
          <a href="/order/status">Order Status</a>
          {isLoggedIn && <a href="/account">Account</a>}
          {!isLoggedIn && <a href="/login">Login</a>}
          {isLoggedIn && <a href="/logout">Logout</a>}
        </nav>
      </aside>
      <section slot="content">
        <Header />
        <slot />
        <Footer />
      </section>
    </kemet-drawer>
    <kemet-alert overlay="top-full" closable>
      <kemet-icon-bootstrap slot="icon" icon="info-circle" size="24"></kemet-icon-bootstrap>
    </kemet-alert>
	</body>
</html>

<script>
  // astro knows to load the following on the client
  // we want these design system elements to load globally
  import 'kemet-ui/elements/drawer';
  import 'kemet-ui/elements/card';
  import 'kemet-ui/elements/button';
  import 'kemet-ui/elements/badge';
  import 'kemet-ui/elements/fab';
  import 'kemet-ui/elements/alert';
  import 'kemet-ui/elements/icon-bootstrap';
  import 'kemet-ui/elements/field';
  import 'kemet-ui/elements/input';
  import 'kemet-ui/elements/textarea';
  import 'kemet-ui/elements/popper';
  import 'kemet-ui/elements/carousel';
  import 'kemet-ui/elements/carousel-slide';
  import 'kemet-ui/elements/carousel-prev';
  import 'kemet-ui/elements/carousel-next';
  import 'kemet-ui/elements/select';
  import 'kemet-ui/elements/option';
  import 'kemet-ui/elements/checkbox';
  import 'kemet-ui/elements/password';

  // app custom elements
  import '../elements/lasz-header';
  import '../elements/lasz-nav-top';
  import '../elements/lasz-product';

  // handle state
  import alertStore from '../stores/alert';
  import type HTMLKemetAlertElement from 'kemet-ui/elements/alert.d.ts';
  import type HTMLKemetIconBootstrapElement from 'kemet-ui/elements/icon-bootstrap.d.ts';

  const alert = document.querySelector('kemet-alert') as HTMLKemetAlertElement;
  const alertIcon = alert.querySelector('kemet-alert kemet-icon-bootstrap') as HTMLKemetIconBootstrapElement;

  alertStore.subscribe((state) => {
    if (state.config) {
      alert.innerHTML = '';
      const message = document.createElement('div');
      message.innerHTML = state.config.message as string;
      alert.opened = state.config.opened;
      alert.status = state.config.status as "standard" | "primary" | "success" | "warning" | "error";
      alertIcon.icon = state.config.icon as string;
      alert.appendChild(message);
      alert.appendChild(alertIcon);
    }
  });
</script>

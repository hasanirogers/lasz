{
  "name": "lasz",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:woocommerce": "turbo run build --filter=@lasz/woocommerce",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apis/*",
    "apps/*",
    "packages/*"
  ]
}
